# Clerk Authentication (get from Clerk Dashboard)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_key_here
VITE_CLERK_PROXY_URL=https://your-domain.clerk.accounts.dev

# Backend API (for production: your deployed backend URL)
# For development: http://localhost/api
# For Vercel + separate backend: https://your-backend-domain.com/api
VITE_API_URL=http://localhost/api

# Supabase (managed server-side only, not exposed to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Admin access control
ADMIN_EMAILS=you@gmail.com,admin@company.com

# Clerk server-side (backend only)
CLERK_SECRET_KEY=sk_live_your_secret_key_here
